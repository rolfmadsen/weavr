              {
                "name": "selectedItem",
                "type": "Custom"
              }
            ],
            "dependencies": []
          },
          {
            "id": "rm_workspace_catalog",
            "title": "Workspace Model Catalog",
            "type": "READMODEL",
            "description": "List of available projects in LocalStorage.",
            "fields": [
              {
                "name": "models",
                "type": "List<ModelMetadata>"
              }
            ],
            "dependencies": []
          }
        ],
        "screens": [
          {
            "id": "scr_modeling_visualization",
